# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=

# Web UI Security
# Required for hosted deployments. Use a long random value.
WEB_PASSWORD=
# Optional: set a separate API token. Defaults to WEB_PASSWORD if empty.
API_AUTH_TOKEN=

# Web UI API connection (change to service name when running via Docker)
API_BASE_URL=http://localhost:8000
